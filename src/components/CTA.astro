---
interface Props {
  variant?: "default" | "olive" | "charcoal";
  eyebrow?: string;
  heading: string;
  body?: string;
  ctaLabel: string;
  ctaHref: string;
  ctaStyle?: "solid" | "light";
}

const {
  variant = "default",
  eyebrow,
  heading,
  body,
  ctaLabel,
  ctaHref,
  ctaStyle = "solid",
} = Astro.props;

const sectionClass = {
  default: "",
  olive: "section--olive",
  charcoal: "section--charcoal",
}[variant];

const onDark = variant === "olive" || variant === "charcoal";
const buttonClass = ctaStyle === "light" ? "btn btn--light" : "btn btn--solid";
---

<section class={`section-base text-center ${sectionClass}`.trim()}>
  <div class="mx-auto max-w-[760px]">
    {eyebrow && <p class={`eyebrow ${onDark ? "on-dark" : ""}`}>{eyebrow}</p>}
    <h2 class="font-serif section-heading mt-4">{heading}</h2>
    {
      body && (
        <p class={`mx-auto mt-6 max-w-[540px] ${onDark ? "text-[rgba(244,239,230,0.8)]" : "text-[rgba(45,42,38,0.7)]"}`}>
          {body}
        </p>
      )
    }
    <a href={ctaHref} class={`${buttonClass} mt-9`}>{ctaLabel}</a>
  </div>
</section>
