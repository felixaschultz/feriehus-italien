---
const navLinks = [
  { href: "/", label: "Hjem" },
  { href: "/canelli/", label: "Canelli" },
  { href: "/galleri/", label: "Galleri" },
  { href: "/kontakt/", label: "Kontakt" },
  { href: "/faq/", label: "FAQ" },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--color-charcoal)] text-[rgba(244,239,230,0.75)] px-6 pt-20 pb-8">
  <div class="mx-auto grid max-w-[1180px] gap-14 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <p class="font-serif mb-4 text-[22px] tracking-[0.28em] text-[var(--color-cream)]">
        CASA SANTA LIBERA
      </p>
      <p class="max-w-[320px] leading-[1.7]">
        Et charmerende feriehus midt i Piemontes vinmarker — mellem ro,
        udsigt og italiensk livsglæde.
      </p>
    </div>
    <div>
      <h4 class="mb-4 text-[11px] font-medium uppercase tracking-[0.32em] text-[var(--color-cream)]">
        Adresse
      </h4>
      <p class="leading-[1.7]">
        Santa Libera-regionen 45<br />
        14053 Canelli — Asti (AT)<br />
        Italien
      </p>
    </div>
    <div>
      <h4 class="mb-4 text-[11px] font-medium uppercase tracking-[0.32em] text-[var(--color-cream)]">
        Naviger
      </h4>
      <ul class="m-0 list-none p-0">
        {
          navLinks.map((link) => (
            <li class="mt-[10px] first:mt-0">
              <a
                href={link.href}
                class="text-[rgba(244,239,230,0.75)] no-underline transition-colors hover:text-[var(--color-terracotta)]"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
  <div class="mx-auto mt-14 flex max-w-[1180px] flex-wrap justify-between gap-3 border-t border-[rgba(244,239,230,0.1)] pt-6 text-[11px] tracking-[0.08em] text-[rgba(244,239,230,0.45)]">
    <span>© {currentYear} Casa Santa Libera</span>
    <span>Astro · View Transitions</span>
  </div>
</footer>
