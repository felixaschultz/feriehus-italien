---
interface Props {
  eyebrow?: string;
  heading: string;
  linkLabel?: string;
  linkHref?: string;
  centered?: boolean;
  onDark?: boolean;
}

const {
  eyebrow,
  heading,
  linkLabel,
  linkHref,
  centered = false,
  onDark = false,
} = Astro.props;
---

{
  centered ? (
    <div class="mx-auto mb-14 max-w-[640px] text-center">
      {eyebrow && <p class={`eyebrow ${onDark ? "on-dark" : ""}`}>{eyebrow}</p>}
      <h2 class="font-serif section-heading mt-4">{heading}</h2>
    </div>
  ) : (
    <div class="section-header">
      <div>
        {eyebrow && <p class={`eyebrow ${onDark ? "on-dark" : ""}`}>{eyebrow}</p>}
        <h2 class="font-serif section-heading">{heading}</h2>
      </div>
      {linkLabel && linkHref && (
        <a href={linkHref} class="link whitespace-nowrap">
          {linkLabel}
        </a>
      )}
    </div>
  )
}
