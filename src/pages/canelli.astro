---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Cards from "../components/Cards.astro";
import CTA from "../components/CTA.astro";

const cards = [
  {
    eyebrow: "Vinsmagninger",
    title: "Vingårde i verdensklasse",
    body: "Området omkring Canelli er hjem for nogle af Italiens mest respekterede vinproducenter. Bestil en privat vinsmagning hos en lokal producent — ofte gratis hvis I køber et par flasker med.",
  },
  {
    eyebrow: "Byer & kultur",
    title: "Asti, Alba & Barolo",
    body: "Charmerende middelalderbyer ligger i kort køreafstand. Asti er kendt for sin gastronomi, Alba for trøfler, og Barolo-området for nogle af verdens fineste rødvine.",
  },
  {
    eyebrow: "Natur",
    title: "Cykling & vandring",
    body: "De kuperede vinbakker er ideelle til både e-bike og lange vandreture. Lokale skilteruter fører jer forbi UNESCO's smukkeste udsigtspunkter — perfekt til en formiddag eller hel dag.",
  },
  {
    eyebrow: "Mad & marked",
    title: "Lokale markeder & gastronomi",
    body: "I Canelli er der marked tirsdag og fredag formiddag med friske grøntsager, oste, slagtervarer og specialiteter. Restauranterne i området serverer ægte piemontesisk køkken med en moderne tilgang.",
  },
];
---

<BaseLayout
  title="Canelli & Santa Libera — Casa Santa Libera"
  description="Canelli er en af Italiens vigtigste vinbyer, kendt for mousserende vine og UNESCO-beskyttede underjordiske vinkældre. Læs mere om området omkring Casa Santa Libera."
>
  <Hero
    image="https://picsum.photos/seed/canelli-town/2400/1300"
    imageAlt="Canelli i Piemonte"
    eyebrow="Området"
    title="Canelli & Santa Libera"
    subtitle="Midt i Piemontes UNESCO-beskyttede vinlandskaber."
  />

  <Section narrow>
    <p class="eyebrow">Vinbyen</p>
    <h2 class="font-serif section-heading mt-4">
      Italiens hjerte for mousserende vin
    </h2>
    <div class="lead mt-8">
      <p>
        Canelli er kendt som en af Italiens vigtigste vinbyer og er især berømt
        for sine mousserende vine. Byen byder på hyggelige restauranter,
        vinbarer og historiske vinkældre — bl.a. de UNESCO-beskyttede
        "underjordiske katedraler".
      </p>
    </div>
  </Section>

  <Section variant="white">
    <div class="split">
      <div>
        <p class="eyebrow">Santa Libera</p>
        <h2 class="font-serif section-heading mt-4">
          Roligt og naturskønt — ganske få minutter fra centrum
        </h2>
        <p class="lead mt-7">
          Casa Santa Libera ligger i et stille område omgivet af vinmarker og
          bakker, men kun en kort køretur fra Canellis hyggelige torv, caféer
          og vinbarer. Her får I det bedste fra to verdener: ro og udsigt om
          dagen, italiensk byliv om aftenen.
        </p>
      </div>
      <img
        class="aspect-portrait"
        src="https://picsum.photos/seed/santa-libera-area/900/1100"
        alt="Santa Libera-området ved Canelli"
        loading="lazy"
      />
    </div>
  </Section>

  <Section variant="soft">
    <SectionHeader
      eyebrow="Oplev Piemonte"
      heading="Hvad du kan opleve"
      centered
    />
    <Cards cards={cards} />
  </Section>

  <Section variant="white">
    <SectionHeader eyebrow="På kortet" heading="Sådan finder du os" centered />
    <iframe
      class="map-embed"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      src="https://maps.google.com/maps?q=Santa%20Libera%2C%20Canelli%2C%20Asti%2C%20Italy&t=&z=11&ie=UTF8&iwloc=&output=embed"
      title="Kort over Santa Libera, Canelli"
    ></iframe>
  </Section>

  <CTA
    variant="olive"
    eyebrow="Book dit ophold"
    heading="Lyder Piemonte som dit næste eventyr?"
    body="Vi svarer gerne på spørgsmål om huset, området og ledige uger."
    ctaLabel="Kontakt os"
    ctaHref="/kontakt/"
    ctaStyle="light"
  />
</BaseLayout>
