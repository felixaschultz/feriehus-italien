---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Cards from "../components/Cards.astro";
import CTA from "../components/CTA.astro";
import PortableText from "../components/PortableText.astro";
import { fetchCanelliPage } from "../lib/queries";
import { urlFor } from "../lib/sanity";

const data = await fetchCanelliPage();

// Fallback content (used when Sanity isn't configured or the document hasn't
// been published yet). Once the owner publishes content in /studio, that
// content takes over automatically.
const fallback = {
  heroEyebrow: "Området",
  heroTitle: "Canelli & Santa Libera",
  heroSubtitle: "Midt i Piemontes UNESCO-beskyttede vinlandskaber.",
  heroImage: "https://picsum.photos/seed/canelli-town/2400/1300",
  heroImageAlt: "Canelli i Piemonte",

  introEyebrow: "Vinbyen",
  introHeading: "Italiens hjerte for mousserende vin",

  santaLiberaEyebrow: "Santa Libera",
  santaLiberaHeading:
    "Roligt og naturskønt — ganske få minutter fra centrum",
  santaLiberaImage: "https://picsum.photos/seed/santa-libera-area/900/1100",
  santaLiberaImageAlt: "Santa Libera-området ved Canelli",

  experiencesEyebrow: "Oplev Piemonte",
  experiencesHeading: "Hvad du kan opleve",
  experiences: [
    {
      eyebrow: "Vinsmagninger",
      title: "Vingårde i verdensklasse",
      body: "Området omkring Canelli er hjem for nogle af Italiens mest respekterede vinproducenter. Bestil en privat vinsmagning hos en lokal producent — ofte gratis hvis I køber et par flasker med.",
    },
    {
      eyebrow: "Byer & kultur",
      title: "Asti, Alba & Barolo",
      body: "Charmerende middelalderbyer ligger i kort køreafstand. Asti er kendt for sin gastronomi, Alba for trøfler, og Barolo-området for nogle af verdens fineste rødvine.",
    },
    {
      eyebrow: "Natur",
      title: "Cykling & vandring",
      body: "De kuperede vinbakker er ideelle til både e-bike og lange vandreture. Lokale skilteruter fører jer forbi UNESCO's smukkeste udsigtspunkter — perfekt til en formiddag eller hel dag.",
    },
    {
      eyebrow: "Mad & marked",
      title: "Lokale markeder & gastronomi",
      body: "I Canelli er der marked tirsdag og fredag formiddag med friske grøntsager, oste, slagtervarer og specialiteter. Restauranterne i området serverer ægte piemontesisk køkken med en moderne tilgang.",
    },
  ],

  mapQuery: "Santa Libera, Canelli, Asti, Italy",

  ctaEyebrow: "Book dit ophold",
  ctaHeading: "Lyder Piemonte som dit næste eventyr?",
  ctaBody:
    "Vi svarer gerne på spørgsmål om huset, området og ledige uger.",
  ctaLabel: "Kontakt os",
};

const heroImage = data?.heroImage
  ? urlFor(data.heroImage).width(2400).height(1300).fit("crop").auto("format").url()
  : fallback.heroImage;
const heroImageAlt = data?.heroImage?.alt || fallback.heroImageAlt;

const santaLiberaImage = data?.santaLiberaImage
  ? urlFor(data.santaLiberaImage)
      .width(900)
      .height(1100)
      .fit("crop")
      .auto("format")
      .url()
  : fallback.santaLiberaImage;
const santaLiberaImageAlt =
  data?.santaLiberaImage?.alt || fallback.santaLiberaImageAlt;

const experiences = data?.experiences?.length
  ? data.experiences
  : fallback.experiences;

const mapQuery = data?.mapQuery || fallback.mapQuery;
const mapSrc = `https://maps.google.com/maps?q=${encodeURIComponent(
  mapQuery,
)}&t=&z=11&ie=UTF8&iwloc=&output=embed`;
---

<BaseLayout
  title="Canelli & Santa Libera — Casa Santa Libera"
  description="Canelli er en af Italiens vigtigste vinbyer, kendt for mousserende vine og UNESCO-beskyttede underjordiske vinkældre. Læs mere om området omkring Casa Santa Libera."
>
  <Hero
    image={heroImage}
    imageAlt={heroImageAlt}
    eyebrow={data?.heroEyebrow ?? fallback.heroEyebrow}
    title={data?.heroTitle ?? fallback.heroTitle}
    subtitle={data?.heroSubtitle ?? fallback.heroSubtitle}
  />

  <Section narrow>
    <p class="eyebrow">{data?.introEyebrow ?? fallback.introEyebrow}</p>
    <h2 class="font-serif section-heading mt-4">
      {data?.introHeading ?? fallback.introHeading}
    </h2>
    <div class="lead mt-8">
      {
        data?.introBody ? (
          <PortableText blocks={data.introBody} />
        ) : (
          <p>
            Canelli er kendt som en af Italiens vigtigste vinbyer og er især
            berømt for sine mousserende vine. Byen byder på hyggelige
            restauranter, vinbarer og historiske vinkældre — bl.a. de
            UNESCO-beskyttede "underjordiske katedraler".
          </p>
        )
      }
    </div>
  </Section>

  <Section variant="white">
    <div class="split">
      <div>
        <p class="eyebrow">
          {data?.santaLiberaEyebrow ?? fallback.santaLiberaEyebrow}
        </p>
        <h2 class="font-serif section-heading mt-4">
          {data?.santaLiberaHeading ?? fallback.santaLiberaHeading}
        </h2>
        <div class="lead mt-7">
          {
            data?.santaLiberaBody ? (
              <PortableText blocks={data.santaLiberaBody} />
            ) : (
              <p>
                Casa Santa Libera ligger i et stille område omgivet af
                vinmarker og bakker, men kun en kort køretur fra Canellis
                hyggelige torv, caféer og vinbarer. Her får I det bedste fra to
                verdener: ro og udsigt om dagen, italiensk byliv om aftenen.
              </p>
            )
          }
        </div>
      </div>
      <img
        class="aspect-portrait"
        src={santaLiberaImage}
        alt={santaLiberaImageAlt}
        loading="lazy"
      />
    </div>
  </Section>

  <Section variant="soft">
    <SectionHeader
      eyebrow={data?.experiencesEyebrow ?? fallback.experiencesEyebrow}
      heading={data?.experiencesHeading ?? fallback.experiencesHeading}
      centered
    />
    <Cards cards={experiences} />
  </Section>

  <Section variant="white">
    <SectionHeader eyebrow="På kortet" heading="Sådan finder du os" centered />
    <iframe
      class="map-embed"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      src={mapSrc}
      title={`Kort over ${mapQuery}`}
    ></iframe>
  </Section>

  <CTA
    variant="olive"
    eyebrow={data?.ctaEyebrow ?? fallback.ctaEyebrow}
    heading={data?.ctaHeading ?? fallback.ctaHeading}
    body={data?.ctaBody ?? fallback.ctaBody}
    ctaLabel={data?.ctaLabel ?? fallback.ctaLabel}
    ctaHref="/kontakt/"
    ctaStyle="light"
  />
</BaseLayout>
