---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import CTA from "../components/CTA.astro";

const ude = [
  { src: "https://picsum.photos/seed/casa-ude-1/900/700", alt: "Terrasse med udsigt" },
  { src: "https://picsum.photos/seed/casa-ude-2/900/700", alt: "Indgang og facade" },
  { src: "https://picsum.photos/seed/casa-ude-3/900/700", alt: "Have og vinmarker" },
  { src: "https://picsum.photos/seed/casa-ude-4/900/700", alt: "Solnedgang fra terrassen" },
  { src: "https://picsum.photos/seed/casa-ude-5/900/700", alt: "Udekøkken" },
  { src: "https://picsum.photos/seed/casa-ude-6/900/700", alt: "Udsigt over bakker" },
];

const inde = [
  { src: "https://picsum.photos/seed/casa-inde-1/900/700", alt: "Stue med pejs" },
  { src: "https://picsum.photos/seed/casa-inde-2/900/700", alt: "Køkken" },
  { src: "https://picsum.photos/seed/casa-inde-3/900/700", alt: "Spisestue" },
  { src: "https://picsum.photos/seed/casa-inde-4/900/700", alt: "Soveværelse" },
  { src: "https://picsum.photos/seed/casa-inde-5/900/700", alt: "Badeværelse" },
  { src: "https://picsum.photos/seed/casa-inde-6/900/700", alt: "Detalje fra entré" },
];

const vinrum = [
  { src: "https://picsum.photos/seed/casa-vin-1/900/700", alt: "Vinrum oversigt" },
  { src: "https://picsum.photos/seed/casa-vin-2/900/700", alt: "Vinreoler" },
  { src: "https://picsum.photos/seed/casa-vin-3/900/700", alt: "Smagningsbord" },
];
---

<BaseLayout
  title="Galleri — Casa Santa Libera"
  description="Billeder fra Casa Santa Libera — udendørs, indendørs og det unikke vinrum."
>
  <Hero
    image="https://picsum.photos/seed/casa-gallery-hero/2400/1300"
    imageAlt="Galleri — Casa Santa Libera"
    eyebrow="Galleri"
    title="Et hus i billeder"
    subtitle="Tag en visuel rundtur — ude, inde og i det unikke vinrum."
  />

  <Section>
    <nav class="tabs" aria-label="Galleri-sektioner">
      <a href="#ude">Udenfor</a>
      <a href="#inde">Indenfor</a>
      <a href="#vinrum">Vinrum</a>
    </nav>

    <div class="gallery-block" id="ude">
      <h3>Udenfor</h3>
      <GalleryGrid images={ude} columns={3} aspect="landscape" />
    </div>

    <div class="gallery-block" id="inde">
      <h3>Indenfor</h3>
      <GalleryGrid images={inde} columns={3} aspect="landscape" />
    </div>

    <div class="gallery-block" id="vinrum">
      <h3>Vinrum</h3>
      <GalleryGrid images={vinrum} columns={3} aspect="landscape" />
    </div>
  </Section>

  <CTA
    variant="charcoal"
    eyebrow="Kom og oplev det selv"
    heading="Klar til en ferie i Piemonte?"
    body="Skriv til os for at høre om ledige uger og priser."
    ctaLabel="Kontakt os"
    ctaHref="/kontakt/"
    ctaStyle="light"
  />
</BaseLayout>
